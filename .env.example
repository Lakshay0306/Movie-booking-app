# ============================================
# CineVerse - Environment Configuration
# Copy this file to .env and fill in your values
# ============================================

PORT=3000
NODE_ENV=development

# ========================
# Database (MongoDB Atlas)
# ========================
MONGO_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/cineverse?appName=Cluster0

# ========================
# Redis (Optional - caching)
# ========================
REDIS_HOST=127.0.0.1
REDIS_PORT=6379

# ========================
# JWT Authentication
# ========================
JWT_SECRET=your_jwt_secret_key_here
JWT_REFRESH_SECRET=your_jwt_refresh_secret_key_here

# ========================
# Payment Gateways
# ========================
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxxx
RAZORPAY_KEY_SECRET=your_razorpay_secret
NEXT_PUBLIC_RAZORPAY_KEY=rzp_test_xxxxxxxxxxxxx
VITE_RAZORPAY_KEY=rzp_test_xxxxxxxxxxxxx

# Stripe (Optional)
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_xxxxxxxxxxxxx
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_xxxxxxxxxxxxx

# ========================
# Email / SMTP
# ========================
SMTP_HOST=smtp.mailtrap.io
SMTP_PORT=2525
SMTP_USER=your_smtp_user
SMTP_PASSWORD=your_smtp_password
EMAIL_FROM=noreply@cineverse.com

# ========================
# URLs
# ========================
FRONTEND_URL=http://localhost:3000
API_BASE_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=/api
VITE_API_URL=/api
